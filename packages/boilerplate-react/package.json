{
  "name": "zutron-react-boilerplate",
  "version": "0.0.1",
  "description": "A Typescript/Redux application managing electron processes",
  "main": "./out/main/index.js",
  "author": "goosewobbler",
  "type": "module",
  "scripts": {
    "clean": "pnpx rimraf ./out ./node_modules pnpm-lock.yaml",
    "format": "prettier --check .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "pnpm build && electron-builder --win --config",
    "build:mac": "electron-vite build && electron-builder --mac --config",
    "build:linux": "electron-vite build && electron-builder --linux --config"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.2",
    "electron-store": "^8.2.0",
    "zustand": "^4.5.2",
    "zutron": "file:../zutron"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@types/node": "^20.11.30",
    "@types/react": "18.2.70",
    "@types/react-dom": "18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.14",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "electron-devtools-assembler": "^1.2.0",
    "electron-vite": "^2.1.0",
    "postcss": "^8.4.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "source-map-support": "^0.5.21",
    "tailwindcss": "^3.3.1",
    "tty": "^1.0.1",
    "typescript": "^5.4.3",
    "vite-tsconfig-paths": "^4.2.0"
  }
}
